# ============================================================
# MediGuard — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Google AI / ADK ---
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLOUD_PROJECT=your_project_id

# --- Antigravity Runtime ---
ANTIGRAVITY_ENDPOINT=https://antigravity.googleapis.com
ANTIGRAVITY_AGENT_ID=your_agent_id_here

# --- Application ---
APP_SECRET_KEY=change_this_to_a_random_secret_string
APP_ENV=development   # development | production
DEBUG=true

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./mediguard.db

# --- MCP Server ---
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8001

# --- Notifications (Twilio SMS) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# --- Notifications (SendGrid Email) ---
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@mediguard.app

# --- Caregiver Auth ---
JWT_SECRET=change_this_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
